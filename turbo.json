{
  "$schema": "https://turbo.build/schema.json",
  "envMode": "loose",
  "tasks": {
    "Folo#build:web": {
      "outputs": ["out/**"]
    },
    "//#format:check": {},
    "//#lint": {},
    "test": {},
    "@suhui/electron-main#build": {
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["@suhui/electron-main#build"]
    },
    "build": {
      "outputs": ["dist/**"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    }
  }
}
