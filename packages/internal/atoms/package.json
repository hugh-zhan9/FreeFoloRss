{
  "name": "@suhui/atoms",
  "private": true,
  "sideEffects": false,
  "exports": {
    "./atoms/*": {
      "import": "./src/atoms/*",
      "types": "./src/atoms/*"
    },
    "./helper/*": {
      "import": "./src/helper/*",
      "types": "./src/helper/*"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@suhui/configs": "workspace:*",
    "@suhui/constants": "workspace:*",
    "@suhui/hooks": "workspace:*",
    "@suhui/shared": "workspace:*",
    "@suhui/store": "workspace:*",
    "@suhui/types": "workspace:*",
    "@suhui/utils": "workspace:*",
    "jotai": "2.17.1"
  }
}
