{
  "name": "@suhui/models",
  "private": true,
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    },
    "./rsshub": {
      "import": "./src/rsshub.ts",
      "types": "./src/rsshub.ts"
    },
    "./types": {
      "import": "./src/types.ts",
      "require": "./src/types.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@follow-app/client-sdk": "catalog:",
    "@suhui/constants": "workspace:*",
    "@suhui/shared": "workspace:*",
    "@suhui/types": "workspace:*",
    "@suhui/utils": "workspace:*"
  },
  "devDependencies": {
    "@suhui/configs": "workspace:*"
  }
}
